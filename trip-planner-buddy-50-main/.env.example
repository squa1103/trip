# Supabase（與專案 README 一致）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenWeather API（行程頁「天氣追蹤」用）
# https://openweathermap.org/api
# GitHub Pages：在 Repo → Settings → Secrets and variables → Actions 新增同名 Repository secret，
# 並確保 .github/workflows 的 Build 步驟有帶入（見 pages-deploy.yml）。
VITE_WEATHER_API_KEY=

# Google Maps JavaScript API（後台行程編輯地圖 + Places Autocomplete 用）
# 需在 Google Cloud Console 啟用：Maps JavaScript API、Places API
# https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=
